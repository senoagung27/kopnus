{
  "info": {
    "name": "MX100 Job Portal API",
    "description": "REST API untuk portal MX100 (Laravel). Set environment `base_url` (e.g. http://localhost:8000/api) dan `token` dari login/register. Header Authorization: Bearer {{token}} untuk route yang memerlukan auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" },
    { "key": "job_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (employer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"PT Contoh\",\n  \"email\": \"employer@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"employer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/v1/register"
          }
        },
        {
          "name": "Register (freelancer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Freelancer\",\n  \"email\": \"freelancer@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\",\n  \"role\": \"freelancer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/v1/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employer@mx100.test\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/v1/login"
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/user"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/logout"
          }
        }
      ]
    },
    {
      "name": "Employer",
      "item": [
        {
          "name": "List my jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/employer/jobs"
          }
        },
        {
          "name": "Create job (draft)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Backend Developer\",\n  \"description\": \"Membangun API dengan Laravel.\",\n  \"status\": \"draft\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/v1/employer/jobs"
          }
        },
        {
          "name": "Get job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/employer/jobs/{{job_id}}"
          }
        },
        {
          "name": "Update job",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Backend Developer (updated)\",\n  \"description\": \"Deskripsi diperbarui.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/v1/employer/jobs/{{job_id}}"
          }
        },
        {
          "name": "Publish job",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/employer/jobs/{{job_id}}/publish"
          }
        },
        {
          "name": "List applications (CVs) for job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/employer/jobs/{{job_id}}/applications"
          }
        },
        {
          "name": "Delete job",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/employer/jobs/{{job_id}}"
          }
        }
      ]
    },
    {
      "name": "Freelancer",
      "item": [
        {
          "name": "List published jobs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/jobs"
          }
        },
        {
          "name": "Get published job",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/v1/jobs/{{job_id}}"
          }
        },
        {
          "name": "Submit application (CV)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "cover_letter", "type": "text", "value": "Saya tertarik dengan posisi ini." },
                { "key": "cv", "type": "file", "src": "", "disabled": true }
              ]
            },
            "url": "{{base_url}}/v1/jobs/{{job_id}}/applications"
          }
        }
      ]
    }
  ]
}
