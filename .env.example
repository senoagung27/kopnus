APP_NAME=MX100
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Pakai 127.0.0.1 — pastikan user MySQL punya GRANT untuk host yang sama (lihat README).
# Artisan di Mac + MySQL di Docker: DB_HOST=127.0.0.1 dan DB_PORT=33060 (bukan 3306), sandi = DB_PASSWORD yang dipakai Compose saat volume MySQL pertama kali dibuat.
# Artisan di dalam kontainer app: DB_HOST=mysql (atau db), DB_PORT=3306.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mx100
# Hindari root di lokal (sering error 1698). Buat user khusus, mis. mx100, lalu isi sandinya di bawah.
DB_USERNAME=mx100
DB_PASSWORD=12341234

# Opsional pengujian cepat tanpa MySQL (phpunit.xml mengoverride ke sqlite :memory:)
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
